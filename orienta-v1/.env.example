# URL publica do app (mesma porta do `npm run dev`, ex.: http://localhost:3000).
# Em Vercel: defina por ambiente (Production vs Preview). Ver docs/operations/DEPLOY-VERCEL.md e .env.vercel.example.
NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_DEFAULT_ORGANIZATION_ID=
NEXT_PUBLIC_DEFAULT_FORM_ID=
NEXT_PUBLIC_DEFAULT_RESPONDENT_USER_ID=
NEXT_PUBLIC_DEFAULT_ADMIN_USER_ID=

# Somente desenvolvimento (opcional). Se definir como "1" com NODE_ENV=development,
# a API pode aceitar requisicoes sem Bearer token usando o primeiro perfil do banco
# para cada role permitida (fallback de perfil). Ver `src/lib/api/auth.ts`.
# Nao use em producao.
ALLOW_DEV_PROFILE_FALLBACK=
