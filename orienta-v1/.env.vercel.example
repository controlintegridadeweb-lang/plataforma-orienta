# Copie estas variaveis no painel Vercel (Project > Settings > Environment Variables).
# Nao commite valores reais. Use Production / Preview conforme a tabela em docs/DEPLOY-VERCEL.md.

# --- Obrigatorias (Production + Preview/staging) ---
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-or-publishable-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret>

# URL publica do deploy (auth e links de e-mail). Ajuste por ambiente:
# Production: https://<seu-projeto>.vercel.app ou dominio customizado
# Preview (branch staging): https://<projeto>-git-staging-<team>.vercel.app
NEXT_PUBLIC_APP_URL=https://<seu-projeto>.vercel.app

# --- Opcionais (homologacao nas telas; pode omitir em producao externa) ---
NEXT_PUBLIC_DEFAULT_ORGANIZATION_ID=
NEXT_PUBLIC_DEFAULT_FORM_ID=
NEXT_PUBLIC_DEFAULT_RESPONDENT_USER_ID=
NEXT_PUBLIC_DEFAULT_ADMIN_USER_ID=

# --- Nunca em Production ---
# ALLOW_DEV_PROFILE_FALLBACK=1   # somente Preview local/dev, se necessario
